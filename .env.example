AIRFLOW_ADMIN_PASSWORD=ChangeMe_Airflow123!
 
# ── Superset ─────────────────────────────────────────────────
SUPERSET_SECRET_KEY=change_me_superset_secret
 
# ── HashiCorp Vault ──────────────────────────────────────────
VAULT_DEV_ROOT_TOKEN_ID=root
 
# ── API Keys (tam thoi — se chuyen vao Vault) ────────────────
GOOGLE_PLACES_API_KEY=AIzaSyCOAgW_JUyq-g5zbD2KVwEVMTHuzu-ZBpo
TRIPADVISOR_API_KEY=620e33ecd272993bc7612aa6731dbdbcfaa1c20f97ca1bb4c300ec578e656dab # Dùng của SerpAPI 
SERPAPI_KEY=620e33ecd272993bc7612aa6731dbdbcfaa1c20f97ca1bb4c300ec578e656dab

# ── Kafka / Flink (travel profile) ────────────────────────────
KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_EXTERNAL_PORT=9092
# Optional: fixed KRaft cluster ID (22 chars). Keep stable once data dir is created.
KAFKA_KRAFT_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

